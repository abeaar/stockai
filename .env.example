# StockAI Environment Configuration Template
# Copy this file to .env and fill in your values
# CRITICAL: .env is gitignored - NEVER commit secrets to version control

# === LLM API Keys ===
# Google Gemini (Primary)
GOOGLE_API_KEY=your-google-api-key-here

# Available Gemini Models (as of 2026-01-03):
# - gemini-3-flash-preview (Recommended - latest with agentic capabilities)
# - gemini-2.5-flash (Stable, fast, 1M context, thinking mode)
# - gemini-2.5-pro (Most capable, 1M context)
# - gemini-2.0-flash (Stable, 8K output)
# - gemini-2.0-flash-lite (Cost-efficient)

# Default model for StockAI agent
STOCKAI_MODEL=gemini-3-flash-preview

# OpenAI (Alternative)
OPENAI_API_KEY=

# Anthropic (Alternative)
ANTHROPIC_API_KEY=

# === Data Source API Keys ===
# Firecrawl (Deep Web Research)
FIRECRAWL_API_KEY=

# Tavily (Web Search - Optional)
TAVILY_API_KEY=

# === Application Settings ===
# Database path (relative to project root)
STOCKAI_DB_PATH=data/stockai.db

# Cache TTL in seconds
STOCKAI_CACHE_TTL=900

# Log level (DEBUG, INFO, WARNING, ERROR)
STOCKAI_LOG_LEVEL=INFO

# Default stock index focus
STOCKAI_DEFAULT_INDEX=IDX30

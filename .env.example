# StockAI Environment Configuration Template
# Copy this file to .env and fill in your values
# CRITICAL: .env is gitignored - NEVER commit secrets to version control

# === LLM API Keys ===
# Google Gemini (Primary)
GOOGLE_API_KEY=your-google-api-key-here

# Available Gemini Models (as of 2026-01-03):
# - gemini-3-flash-preview (Recommended - latest with agentic capabilities)
# - gemini-2.5-flash (Stable, fast, 1M context, thinking mode)
# - gemini-2.5-pro (Most capable, 1M context)
# - gemini-2.0-flash (Stable, 8K output)
# - gemini-2.0-flash-lite (Cost-efficient)

# Default model for StockAI agent
STOCKAI_MODEL=gemini-3-flash-preview

# OpenAI (Alternative)
OPENAI_API_KEY=

# Anthropic (Alternative)
ANTHROPIC_API_KEY=

# === Data Source API Keys ===
# Firecrawl (Deep Web Research)
FIRECRAWL_API_KEY=

# Tavily (Web Search - Optional)
TAVILY_API_KEY=

# === Application Settings ===
# Database path (relative to project root)
STOCKAI_DB_PATH=data/stockai.db

# Cache TTL in seconds
STOCKAI_CACHE_TTL=900

# Log level (DEBUG, INFO, WARNING, ERROR)
STOCKAI_LOG_LEVEL=INFO

# Default stock index focus
STOCKAI_DEFAULT_INDEX=IDX30

# === Intraday Module ===
# Minimum composite score (0-10) to include a name in the daily intraday
# report. Calibrated against the 6M walk-forward backtest:
#   scores 6.5-8.5  -> +0.20R to +0.59R expectancy (POSITIVE edge)
#   scores below 6.5 -> roughly break-even
#   scores above 8.5 -> rare, exhaustion risk
# Lower this to see more names; raise it (e.g. 7.0) to be more selective.
STOCKAI_INTRADAY_MIN_SCORE=6.5

# === Push notifications (for cron-driven daily workflow) ===
# Discord incoming webhook URL. Create one at:
#   Server Settings -> Integrations -> Webhooks -> New Webhook
# Leave empty to disable Discord delivery.
STOCKAI_DISCORD_WEBHOOK_URL=

# Telegram bot credentials (alternative to Discord). Talk to @BotFather.
STOCKAI_TELEGRAM_BOT_TOKEN=
STOCKAI_TELEGRAM_CHAT_ID=
